# ──────────────────────────────────────────────────────────────
# Hala Commercial Engine — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────

# Supabase project URL (from Supabase Dashboard → Settings → API)
SUPABASE_URL=https://your-project.supabase.co

# Service role key — server-side only. NEVER expose to the frontend.
# Supabase Dashboard → Settings → API → Project API keys → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Allowed CORS origin for the frontend (default: http://localhost:3000)
FRONTEND_ORIGIN=http://localhost:3000

# Optional: override the Vite dev server URL the frontend calls for API requests
# VITE_API_URL=http://localhost:3001

# GHL (GoHighLevel) CRM credentials — Sprint 8
# GHL_API_KEY=your-ghl-api-key
# GHL_LOCATION_ID=your-location-id
